  "model": "claude-fable-5[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/settings-mirror-reminder.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/single-page-rule.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/hook-registry-mirror-reminder.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/canonical-edit-threshold.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/memory-agent-handoff-check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/post-write-verify.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/personal-context-identity.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/personal-context-decisions.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/personal-context-howiwork.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/personal-context-voice.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/personal-context-process.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/personal-context-life.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/personal-context-shelf.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/personal-context-runtime.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/yourname/.claude/hooks/bedtime-lockout.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 /Users/yourname/.claude/hooks/context-router.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "compound-engineering@compound-engineering-plugin": true,
    "superpowers@superpowers-dev": true
  },
  "extraKnownMarketplaces": {
    "compound-engineering-plugin": {
      "source": {
        "source": "git",
        "url": "https://github.com/EveryInc/compound-engineering-plugin.git"
      }
    },
    "superpowers-dev": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers"
      }
    }
  },
  "tui": "fullscreen",
  "theme": "dark-ansi",
  "skipAutoPermissionPrompt": true,
  "autoUpdates": true
}
